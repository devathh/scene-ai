        "/api/v1/ai/scenario": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Trigger AI to generate a new scenario based on a prompt.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "AI"
                ],
                "summary": "Generate AI scenario",
                "parameters": [
                    {
                        "description": "Generation prompt",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/github_com_devathh_scene-ai_internal_common_dtos.GenerateScenarioRequest"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Job accepted, returns scenario ID",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request",
                        "schema": {
                            "$ref": "#/definitions/github_com_devathh_scene-ai_internal_common_dtos.ErrMsg"
                        }
                    }
                }
            }
        },
        "/api/v1/ai/scenario/{id}": {
            "get": {
                "description": "Retrieve the status and details of an AI-generated scenario.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "AI"
                ],
                "summary": "Get AI scenario status",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Scenario ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Scenario details",
                        "schema": {
                            "$ref": "#/definitions/github_com_devathh_scene-ai_internal_common_dtos.Scenario"
                        }
                    },
                    "400": {
                        "description": "Invalid ID",
                        "schema": {
                            "$ref": "#/definitions/github_com_devathh_scene-ai_internal_common_dtos.ErrMsg"
                        }
                    }
                }
            }
        },
