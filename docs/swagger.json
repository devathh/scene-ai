                    "application/json"
                ],
                "tags": [
                    "AI"
                ],
                "summary": "Get generated scenes",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Scenario ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
